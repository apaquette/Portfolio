<div class="card m-2 scale" style="width: 300px; text-align: left;">
    <div class="card-body">
        <div class="d-flex justify-content-between">
            <h5 class="card-title" style="margin-bottom: 0;">@Title</h5>
        </div>
        @if(!string.IsNullOrEmpty(Subtitle)){
            <div class="card-subtitle" style="font-style: italic;">@Subtitle</div>
        }
        @ChildContent
    </div>
</div>